{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "baseUrl": ".",
    "outDir": "dist",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "paths": {
      "@common/*": ["./common/*"],
      "@main/*": ["./main/*"],
      "@renderer/*": ["./renderer/*"],
      "@locales/*": ["./locales/*"],
    },
  }
}
